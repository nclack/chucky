{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "results.schema.json",
  "title": "Sweep Results File",
  "description": "Top-level structure of a benchmark sweep results JSON file.",
  "type": "object",
  "required": ["version", "machine", "runs"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "machine": {
      "type": "object",
      "required": ["hostname", "gpu", "commit", "date"],
      "properties": {
        "hostname": { "type": "string", "description": "Machine hostname." },
        "gpu": { "type": "string", "description": "GPU model name from nvidia-smi." },
        "commit": { "type": "string", "description": "Short git commit hash." },
        "date": { "type": "string", "description": "ISO 8601 date-time when the sweep started." }
      },
      "additionalProperties": false
    },
    "runs": {
      "type": "array",
      "items": { "$ref": "run.schema.json" }
    }
  },
  "additionalProperties": false
}
